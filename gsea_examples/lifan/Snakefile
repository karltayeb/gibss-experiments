# GSEA on Lifan's factor analysis vs MSigDB. Run from gsea_examples/lifan/.
#
# Local:   uv run snakemake -c6
# Cluster: uv run snakemake --workflow-profile profiles/slurm   (Midway3 SLURM)
#
# convert (R) -> prep (align + cache design/factor) -> fit (one job/factor/method) -> gather.
#
# Per-rule mem_mb / runtime (minutes) / threads are declared on each rule so they
# travel with the workflow; the SLURM executor maps them to sbatch. Cluster-only
# knobs (account, partition, concurrency) live in profiles/slurm/config.yaml.

configfile: "config.yaml"

RESULTS = "results"
RESOURCES = "resources"

N_FACTORS = config["n_factors"]
ALL_FACTORS = [f"factor_{i:03d}" for i in range(1, N_FACTORS + 1)]
_selected = config.get("factors")
TARGET_FACTORS = ALL_FACTORS if not _selected else [f"factor_{int(i):03d}" for i in _selected]

METHODS = list(config["methods"])
SUSIE_METHODS = [m for m in METHODS if config["methods"][m]["family"] != "ora"]
ORA_METHODS = [m for m in METHODS if config["methods"][m]["family"] == "ora"]

GENE_INFO_URL = (
    "https://ftp.ncbi.nlm.nih.gov/gene/DATA/GENE_INFO/Mammalia/Homo_sapiens.gene_info.gz"
)


def resolved_spec(method):
    return {**config["model_defaults"], **config["methods"][method]}


wildcard_constraints:
    factor=r"factor_\d{3}",
    method=r"[A-Za-z0-9_]+",


# Trivial jobs (curl / a polars concat): run on the submit host, don't queue them.
localrules:
    download_geneinfo,
    gather,


rule all:
    input:
        expand(f"{RESULTS}/{{factor}}/results.parquet", factor=TARGET_FACTORS),
        expand(f"{RESULTS}/fits/{{factor}}/{{method}}.parquet", factor=TARGET_FACTORS, method=ORA_METHODS),


rule download_geneinfo:
    output:
        gene_info=f"{RESOURCES}/Homo_sapiens.gene_info.gz",
    shell:
        "curl -sSL -o {output.gene_info} " + GENE_INFO_URL


rule convert:
    input:
        rds=ancient(config["rds"]),
        gene_info=ancient(f"{RESOURCES}/Homo_sapiens.gene_info.gz"),
    output:
        mapping=f"{RESULTS}/genes/gene_mapping.tsv",
        factors=expand(f"{RESULTS}/factors/{{factor}}.tsv", factor=ALL_FACTORS),
    params:
        factors_dir=f"{RESULTS}/factors",
        n_factors=N_FACTORS,
    threads: 1
    resources:
        mem_mb=16000,   # loads the 74 MB RDS + builds the id->Entrez lookups
        runtime=45,
    shell:
        "Rscript scripts/convert_rds.R {input.rds} {input.gene_info} "
        "{params.n_factors} {output.mapping} {params.factors_dir}"


rule prep:
    input:
        factor_tsv=f"{RESULTS}/factors/{{factor}}.tsv",
    output:
        design=f"{RESULTS}/prep/{{factor}}_design.npz",
        sets=f"{RESULTS}/prep/{{factor}}_sets.parquet",
    params:
        # declared here (not read from config inside the script) so Snakemake's
        # params rerun-trigger invalidates prep when any of them change.
        collection=config["collection"],
        min_set_size=config["min_set_size"],
        max_set_size=config["max_set_size"],
        score=config["score"],
        lfsr_floor=config["lfsr_floor"],
        sd_floor=config["sd_floor"],
    threads: 1
    resources:
        mem_mb=8000,    # loads the MSigDB collection + builds the sparse design
        runtime=20,
    script:
        "scripts/prep.py"


rule fit:
    input:
        design=f"{RESULTS}/prep/{{factor}}_design.npz",
        sets=f"{RESULTS}/prep/{{factor}}_sets.parquet",
    output:
        f"{RESULTS}/fits/{{factor}}/{{method}}.parquet",
    params:
        spec=lambda wc: resolved_spec(wc.method),
        thresholds=config["thresholds"],
    threads: 2   # fit_cell.py caps JAX/BLAS threadpools to this (avoids node oversubscription)
    resources:
        mem_mb=8000,    # dense design (~n_genes x n_sets f32) + JAX runtime
        runtime=240,    # L=20 coarse/logistic fits ran up to ~85 min on pilot factors;
                        # 4h cap gives headroom so the slowest factors don't hit TIMEOUT
    script:
        "scripts/fit_cell.py"


rule gather:
    input:
        lambda wc: expand(f"{RESULTS}/fits/{wc.factor}/{{m}}.parquet", m=SUSIE_METHODS),
    output:
        f"{RESULTS}/{{factor}}/results.parquet",
    run:
        import polars as pl
        pl.concat([pl.read_parquet(f) for f in input], how="vertical").write_parquet(output[0])
